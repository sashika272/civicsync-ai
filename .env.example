# Backend Environment Variables (Production)
NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/civicsync
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend Environment Variables (Production)
# Used if you build the frontend using Vite
VITE_API_URL=https://api.civicsync.com
